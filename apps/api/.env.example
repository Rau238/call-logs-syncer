# Server
PORT=3000
NODE_ENV=development

# PostgreSQL — update these to match your pgAdmin 4 server
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=call_log_sync

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=24h

# Security
API_KEY_SALT=change-this-api-key-salt-in-production
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Public URL (ngrok — same for API + dashboard + mobile)
PUBLIC_URL=https://ninth-rebalance-deny.ngrok-free.dev

# CORS (* = same-origin dashboard + ngrok)
CORS_ORIGIN=*
